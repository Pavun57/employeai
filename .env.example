# EmployAI Environment Variables
# Copy this to .env and fill in your values

# === Database (Supabase) ===
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/employeai

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM Provider ===
# Options: "grok" | "lmstudio" | "openai_compatible"
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=your-api-key
LLM_MODEL=default

# === Grok API (if using Grok) ===
GROK_API_KEY=your-grok-api-key
GROK_BASE_URL=https://api.x.ai/v1

# === Integration OAuth Secrets ===
# Google (Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback

# Instagram / Meta
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/integrations/instagram/callback

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/integrations/linkedin/callback

# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/integrations/shopify/callback

# === App Config ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:8000
SECRET_KEY=change-this-to-a-random-secret-key
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
